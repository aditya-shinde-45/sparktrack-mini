# ============================================================
# SparkTrack Backend – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production            # development | production | lambda
PORT=5000

# ── JWT ─────────────────────────────────────────────────────
# Must be >= 32 random characters in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h              # e.g. 1h, 8h, 24h

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (HTTPS URLs in production).
CORS_ALLOWED_ORIGINS=https://sparktrack.mituniversity.edu

# ── Admin Credentials ───────────────────────────────────────
# Option A – single admin (simple deployments)
ADMIN_DEFAULT_USERNAME=
ADMIN_DEFAULT_PASSWORD=        # Must satisfy enterprise password policy
ADMIN_DEFAULT_ROLE=admin

# Option B – multiple admins as JSON array (preferred for production)
# ADMIN_USERS_JSON=[{"id":1,"username":"admin","password":"<strong-pw>","role":"admin"}]

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── AWS S3 ───────────────────────────────────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS=
S3_REGION=ap-south-1           # Must be in the ALLOWED_REGIONS list
S3_BUCKET_NAME=mit-adt-student-documents

# ── Email (SMTP / Gmail) ─────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=                # Use an App Password, not your account password
EMAIL_FROM=noreply@sparktrack.mituniversity.edu

# ── Rate Limiting (optional overrides) ───────────────────────
RATE_LIMIT_MAX_REQUESTS=200    # General API – requests per 15 min per IP
RATE_LIMIT_LOGIN_MAX=10        # Login attempts per 15 min per IP
RATE_LIMIT_OTP_MAX=5           # OTP requests per 15 min per IP
RATE_LIMIT_PASSWORD_MAX=5      # Password reset attempts per 15 min per IP
RATE_LIMIT_VALIDATE_MAX=30     # Token validation calls per 15 min per IP
